{
  "name": "@repo/database",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "description": "Database package for clinic",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "require": "./dist/index.js",
    "import": "./dist/index.mjs"
  },
  "scripts": {
    "dev": "env-cmd -f .env.development prisma generate && tsup --watch",
    "build": "env-cmd -f .env.development prisma generate && tsup",
    "db:push": "env-cmd -f .env.development prisma db push",
    "db:gen": "env-cmd -f .env.development prisma generate",
    "db:studio": "env-cmd -f .env.development prisma studio",
    "db:seed": "env-cmd -f .env.development prisma db seed",
    "db:format": "env-cmd -f .env.development prisma format",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "6.19",
    "@repo/typescript-config": "*",
    "prisma": "6.19",
    "prisma-zod-generator": "^2.1.2",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^10.0.0",
    "env-cmd": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.6.0"
}
