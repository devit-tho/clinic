model Treatment {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId

  /// @zod.string.min(3, 'errors.type_at_least_3_characters')
  type      String

  /// @zod.custom.use(z.number().positive('error.price_must_be_positive'))
  price     Float     @default(0)

  coverage TreatmentCoverage @default(PARTIAL)

  teeth     Int[]    @default([])

  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String    @map("created_by") @db.ObjectId
  user      User      @relation(fields: [createdBy], references: [id])
  updatedAt DateTime? @map("updated_at")
  updatedBy String?   @map("updated_by") @db.ObjectId
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.ObjectId

  details Detail[]

  @@map("treatments")
}

enum TreatmentCoverage {
  NONE
  FULL
  PARTIAL
}