{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },

    "@repo/database#dev": { "persistent": true },
    "@repo/entities#dev": { "persistent": true },
    "@repo/schemas#dev": { "persistent": true },
    "@repo/backend#dev": { "persistent": true },
    "@repo/admin#dev": { "persistent": true },

    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    }
  }
}
