{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "@repo/admin#build": {
      "env": ["PORT, WEB_API"]
    },
    "@repo/backend#build": {
      "env": ["PORT", "DATABASE_URL", "JWT_SECRET", "JWT_EXPIRES_IN"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
