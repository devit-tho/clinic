{
  "version": 2,
  "installCommand": "corepack enable && yarn install --immutable",
  "buildCommand": "yarn workspaces foreach -pt --all --include=packages/* run build && turbo run build --filter=@repo/backend",
  "builds": [
    {
      "src": "dist/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    }
  ]
}
