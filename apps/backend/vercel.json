{
  "version": 2,
  "installCommand": "corepack enable && yarn set version berry && yarn install --immutable",
  "buildCommand": "yarn workspaces foreach -pt --all --include=packages/* run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    }
  ]
}
