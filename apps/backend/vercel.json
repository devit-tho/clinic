{
  "version": 2,
  "installCommand": "corepack enable && yarn install",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=4096' turbo run build --filter=@repo/backend",
  "outputDirectory": "apps/backend/dist",
  "functions": {
    "api/main.js": {
      "runtime": "nodejs18.x",
      "memory": 1024
    }
  },
  "routes": [{ "src": "/(.*)", "dest": "api/main.js" }]
}
