{
  "version": 2,
  "installCommand": "corepack enable && yarn set version berry && yarn install --immutable",
  "buildCommand": "yarn workspaces foreach -pt --exclude @ackh-repo/admin run build",
  "outputDirectory": "apps/backend/dist",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    }
  ]
}
